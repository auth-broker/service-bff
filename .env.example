# environment
APP_ENV=development
TRUSTED_PROXY_IPS=["*"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]
ALLOWED_ORIGINS=["http://localhost:9998","http://127.0.0.1:9998"]

# logging
LOGGING_CONFIG_LEVEL=DEBUG
LOGGING_CONFIG_NAMESPACES=["", "uvicorn"]

# database settings
DATABASE_TYPE=SQL_ALCHEMY
DATABASE_SQL_ALCHEMY_URL=sqlite+aiosqlite:///data/data.db

# alembic-auto-migrate settings
# postgresdb
# ALEMBIC_AUTO_MIGRATE_DB_URL=postgresql+psycopg://user:password@localhost:5432/bff
# sqlitedb
ALEMBIC_AUTO_MIGRATE_DB_URL=sqlite:///data/data.db
ALEMBIC_AUTO_MIGRATE_INI_PATH=alembic.ini
ALEMBIC_AUTO_MIGRATE_SCRIPT_LOCATION=alembic
ALEMBIC_AUTO_MIGRATE_AUTOGENERATE=true
ALEMBIC_AUTO_MIGRATE_MIGRATION_MESSAGE=autogenerated at startup
ALEMBIC_AUTO_MIGRATE_COMPARE_TYPE=true
ALEMBIC_AUTO_MIGRATE_COMPARE_SERVER_DEFAULT=true
ALEMBIC_AUTO_MIGRATE_INCLUDE_SCHEMAS=false

# Auth-broker integration

AUTH_SERVICE_BASE_URL=http://localhost:8000/
TOKEN_VALIDATOR_SERVICE_BASE_URL=http://localhost:8001/
USER_SERVICE_BASE_URL=http://localhost:8002/
TOKEN_ISSUER_SERVICE_BASE_URL=http://localhost:8003/
TOKEN_ISSUER_STORE_SERVICE_BASE_URL=http://localhost:8004/
TOKEN_STORE_SERVICE_BASE_URL=http://localhost:8005/

# --- token validator service

TOKEN_VALIDATOR_TYPE=OIDC
TOKEN_VALIDATOR_OIDC_ALGORITHMS='["RS256"]'
TOKEN_VALIDATOR_OIDC_ISSUERS='[{"issuer":"https://authentik.matthewcoulter.dev/application/o/auth-broker-web/","jwks_uri":"https://authentik.matthewcoulter.dev/application/o/auth-broker-web/jwks/","audience":["cUdr3ZNSREvqdY4iC5ZiR8NSNuNXb0y7liy1tkB0"]},{"issuer":"https://authentik.matthewcoulter.dev/application/o/auth-broker-n8n/","jwks_uri":"https://authentik.matthewcoulter.dev/application/o/auth-broker-n8n/jwks/","audience":["IgINbf9voUIq1ivypol1w2ExTzwmh53adUSapiV5"]}]'

# --- auth client service

O_AUTH2_CLIENT_TYPE=STANDARD
O_AUTH2_CLIENT_STANDARD_CONFIG_CLIENT_ID=cUdr3ZNSREvqdY4iC5ZiR8NSNuNXb0y7liy1tkB0
